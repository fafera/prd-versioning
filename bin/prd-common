#!/bin/bash
#
# Common functions for PRD versioning scripts
# Supports both GitHub (gh) and GitLab (glab) CLI

# Normalize volatile lines (stdin -> stdout)
#
# Replaces the value of version/timestamp/status lines with a fixed
# placeholder so they never appear as changes (or as mismatched context)
# in the version diffs. Both prd-update (when generating a patch) and
# prd-restore (before reverse-applying) MUST run content through this so
# the patch context matches on both sides.
_normalize_volatile() {
    sed -E \
        -e 's/^(PRD-VERSION:).*/\1 NORMALIZED/' \
        -e 's/^(PRD-UPDATED:).*/\1 NORMALIZED/' \
        -e 's/^(\*\*Versão\*\*).*/\1: NORMALIZED/' \
        -e 's/^(\*\*Atualizado\*\*).*/\1: NORMALIZED/' \
        -e 's/^(\*\*Status\*\*).*/\1: NORMALIZED/'
}

# Extract the unified diff inside the first ```diff fenced block of a comment
# body (stdin -> stdout). Used by prd-restore to recover the patch text.
_extract_diff_block() {
    awk '
        /^```diff[[:space:]]*$/ { inblock=1; next }
        /^```[[:space:]]*$/     { if (inblock) { inblock=0 } ; next }
        inblock { print }
    '
}

# Directory of the target repository for all git lookups. Explicit anchor so
# the skill never reads the wrong repo's remote: PRD_REPO_DIR wins; otherwise
# the git toplevel of the current directory; "." as a last resort. Every git
# call below runs through `git -C "$(_repo_dir)"` so the cwd (which may be the
# skill's own github checkout) can never leak into the resolved target.
_repo_dir() {
    [[ -n "$PRD_REPO_DIR" ]] && { echo "$PRD_REPO_DIR"; return; }
    git rev-parse --show-toplevel 2>/dev/null || echo "."
}

# Slug identifying the current repository, used to namespace the ephemeral
# scratch directory so different projects never collide. Basename of the git
# toplevel; falls back to the remote project path, then to "default".
_repo_slug() {
    local top slug
    top=$(git -C "$(_repo_dir)" rev-parse --show-toplevel 2>/dev/null || echo "")
    if [[ -n "$top" ]]; then
        echo "$(basename "$top")"
        return
    fi
    slug=$(_gitlab_project_path 2>/dev/null | sed -E 's#.*/##')
    [[ -n "$slug" ]] && { echo "$slug"; return; }
    echo "default"
}

# Ephemeral scratch base for this repo: ${TMPDIR:-/tmp}/prd-versioning/<repo>.
# Nothing here is meant to persist between commands — the issue and its
# comments are the only source of truth. Created on demand.
_prd_tmp_base() {
    local base="${TMPDIR:-/tmp}/prd-versioning/$(_repo_slug)"
    mkdir -p "$base" 2>/dev/null
    echo "$base"
}

# Delete an input file, but ONLY when it lives under the scratch base. Guards
# against removing an arbitrary path the caller pointed at outside /tmp.
_prd_cleanup_input() {
    local file="$1"
    [[ -z "$file" || ! -f "$file" ]] && return
    local base="${TMPDIR:-/tmp}/prd-versioning/"
    local resolved
    resolved=$(cd "$(dirname "$file")" 2>/dev/null && pwd)/$(basename "$file")
    if [[ "$resolved" == "$base"* ]]; then
        rm -f "$file"
        echo "🧹 Arquivo temporário removido: $file"
    else
        echo "ℹ️  Arquivo mantido (fora da base temporária): $file"
    fi
}

# Extract the host (e.g. greatcode.aztecweb.net) from the origin remote URL,
# handling both ssh (git@host:path) and https (https://host/path) forms.
_remote_host() {
    local url
    url=$(git -C "$(_repo_dir)" remote get-url origin 2>/dev/null || echo "")
    [[ -z "$url" ]] && url=$(git -C "$(_repo_dir)" remote -v 2>/dev/null | grep -oE '\S+\.\S+' | head -1)
    echo "$url" | sed -E 's#^[a-zA-Z]+://##; s#^[^@]+@##; s#[:/].*$##'
}

# Safety net against operating on the wrong repository. If the target platform
# is gitlab but the resolved remote host is github.com (or vice versa), the
# skill is almost certainly reading some other repo's remote (e.g. its own
# github checkout when run from the skill folder). Abort with an actionable
# message instead of firing a request at the wrong host and failing cryptically.
_guard_remote_matches() {
    local platform="$1" host
    host=$(_remote_host)
    [[ -z "$host" ]] && return 0
    case "$platform" in
        gitlab)
            if [[ "$host" == "github.com" ]]; then
                echo "❌ Plataforma alvo é gitlab, mas o remote resolvido é github.com (host=$host)." >&2
                echo "   Rode da raiz do projeto GitLab ou defina PRD_REPO_DIR=/caminho/do/projeto (ou PRD_GITLAB_PROJECT)." >&2
                exit 1
            fi
            ;;
        github)
            if [[ "$host" == *gitlab* ]]; then
                echo "❌ Plataforma alvo é github, mas o remote resolvido aponta para GitLab (host=$host)." >&2
                echo "   Rode da raiz do projeto correto ou defina PRD_REPO_DIR=/caminho/do/projeto." >&2
                exit 1
            fi
            ;;
    esac
}

# Detect which platform we're using
#
# Order: explicit override -> obvious host name -> CLI host config
# (catches self-hosted GitLab/GitHub on custom domains) -> CLI availability.
_detect_platform() {
    # Check environment variable first
    if [[ -n "$PRD_PLATFORM" ]]; then
        echo "$PRD_PLATFORM"
        return
    fi

    # Check git remote for obvious platform patterns
    local remote
    remote=$(git -C "$(_repo_dir)" remote -v 2>/dev/null || echo "")

    if echo "$remote" | grep -qiE '(gitlab\.|@gitlab|//gitlab)'; then
        echo "gitlab"
        return
    elif echo "$remote" | grep -qiE '(github\.|@github|//github)'; then
        echo "github"
        return
    fi

    # Self-hosted on a custom domain: match the remote host against the hosts
    # each CLI has authenticated to (offline lookup, no network call).
    local host host_re glab_cfg gh_cfg
    host=$(_remote_host)
    if [[ -n "$host" ]]; then
        host_re=$(echo "$host" | sed 's/\./\\./g')
        glab_cfg="${GLAB_CONFIG_DIR:-$HOME/.config/glab-cli}/config.yml"
        gh_cfg="${GH_CONFIG_DIR:-$HOME/.config/gh}/hosts.yml"
        if grep -qE "^[[:space:]]+${host_re}:" "$glab_cfg" 2>/dev/null; then
            echo "gitlab"
            return
        elif grep -qE "^${host_re}:" "$gh_cfg" 2>/dev/null; then
            echo "github"
            return
        fi
    fi

    # GitLab-specific config present? Lean gitlab before guessing by CLI.
    if [[ -n "$PRD_GITLAB_PROJECT" || -n "$GITLAB_HOST" ]]; then
        echo "gitlab"
        return
    fi

    # Fallback: check which CLI is available
    if command -v glab &>/dev/null && ! command -v gh &>/dev/null; then
        echo "gitlab"
    elif command -v gh &>/dev/null && ! command -v glab &>/dev/null; then
        echo "github"
    else
        echo "unknown"
    fi
}

# Get issue URL from output
_get_issue_url_from_output() {
    local output="$1"
    echo "$output" | grep -oE 'https://[^ ]+' | head -1
}

# Get issue number from URL
_get_issue_number_from_url() {
    local url="$1"
    # GitHub: https://github.com/owner/repo/issues/123
    # GitLab: https://gitlab.com/owner/repo/-/issues/123
    # GitLab (newer): https://host/owner/repo/-/work_items/123
    echo "$url" | grep -oE '/(issues|work_items)/[0-9]+' | grep -oE '[0-9]+' | head -1
}

# Derive the GitLab project path (group[/subgroup]/repo) from the origin
# remote, handling ssh (git@host:group/repo.git) and https
# (https://host/group/repo.git) forms. PRD_GITLAB_PROJECT overrides it when
# set, for the rare remote layout the parser can't handle.
_gitlab_project_path() {
    if [[ -n "$PRD_GITLAB_PROJECT" ]]; then
        echo "$PRD_GITLAB_PROJECT"
        return
    fi
    local url
    url=$(git -C "$(_repo_dir)" remote get-url origin 2>/dev/null || echo "")
    [[ -z "$url" ]] && return
    echo "$url" \
        | sed -E 's#^[a-zA-Z]+://##; s#^[^@]+@##; s#^[^/:]+(:[0-9]+)?[:/]+##; s#\.git/?$##; s#/+$##'
}

# Full project URL (https://host/group/repo) built from the remote host and
# project path. Passed to `glab --repo` so glab targets the right host+project
# explicitly, instead of relying on base-repo resolution (which breaks when
# the remote host doesn't match glab's default/configured GITLAB_HOST).
_gitlab_project_url() {
    local host path
    host=$(_remote_host)
    path=$(_gitlab_project_path)
    [[ -z "$host" || -z "$path" ]] && return
    echo "https://$host/$path"
}

# URL-encoded project ref for GitLab API paths. Uses the derived/overridden
# project path; falls back to the :fullpath placeholder when no remote is
# available (preserving the original behaviour).
_gitlab_project_ref() {
    local path
    path=$(_gitlab_project_path)
    [[ -z "$path" ]] && { echo ":fullpath"; return; }
    echo "${path//\//%2F}"
}

# --hostname flag for `glab api`, so requests reach the remote's host even
# when it isn't glab's default configured host. Empty when host is unknown.
_glab_api_host_flag() {
    local host
    host=$(_remote_host)
    [[ -n "$host" ]] && echo "--hostname $host"
}

# --repo flag for `glab issue` subcommands, built from the project URL so
# base-repo resolution never depends on the remote matching GITLAB_HOST.
_glab_repo_flag() {
    local url
    url=$(_gitlab_project_url)
    [[ -n "$url" ]] && echo "--repo $url"
}

# Fetch a single issue as JSON via the GitLab API. Targets the project and
# host derived from the remote (URL-encoded path + --hostname), so it works
# on self-hosted instances regardless of glab's default host. Robust against
# description content that contains '---' or other markup.
_gitlab_issue_json() {
    local iid="$1" out
    _guard_remote_matches gitlab
    out=$(glab api $(_glab_api_host_flag) "projects/$(_gitlab_project_ref)/issues/$iid" 2>/dev/null)
    if ! printf '%s' "$out" | jq empty 2>/dev/null; then
        echo "❌ Resposta não-JSON da API GitLab (host=$(_remote_host), projeto=$(_gitlab_project_path))." >&2
        echo "   Verifique autenticação (glab auth status), host e projeto-alvo." >&2
        return 1
    fi
    printf '%s' "$out"
}

# Create issue
issue_create() {
    local platform=$(_detect_platform)
    local title="$1"
    local body="$2"
    local labels="$3"

    case "$platform" in
        gitlab)
            _guard_remote_matches gitlab
            local repo_flag
            repo_flag=$(_glab_repo_flag)
            if [[ -n "$labels" ]]; then
                glab issue create $repo_flag -y -t "$title" -d "$body" -l "$labels"
            else
                glab issue create $repo_flag -y -t "$title" -d "$body"
            fi
            ;;
        github)
            if [[ -n "$labels" ]]; then
                gh issue create --title "$title" --body "$body" --label "$labels"
            else
                gh issue create --title "$title" --body "$body"
            fi
            ;;
        *)
            echo "❌ Platform not detected. Please set PRD_PLATFORM=github or PRD_PLATFORM=gitlab"
            exit 1
            ;;
    esac
}

# Get issue title
issue_get_title() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _gitlab_issue_json "$issue_number" | jq -r '.title // empty'
            ;;
        github)
            gh issue view "$issue_number" --json title --jq .title 2>/dev/null
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Get issue body/description
issue_get_body() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _gitlab_issue_json "$issue_number" | jq -r '.description // empty'
            ;;
        github)
            gh issue view "$issue_number" --json body --jq .body 2>/dev/null
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Get issue comments/notes
issue_get_comments() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            # Notes as JSON, oldest first, large page to cover long chains.
            # Both GitHub comments and GitLab notes expose a `.body`, so the
            # callers' `jq '.[].body'` works uniformly across platforms.
            _guard_remote_matches gitlab
            local notes
            notes=$(glab api $(_glab_api_host_flag) "projects/$(_gitlab_project_ref)/issues/$issue_number/notes?per_page=100&sort=asc" 2>/dev/null)
            if ! printf '%s' "$notes" | jq empty 2>/dev/null; then
                echo "❌ Resposta não-JSON da API GitLab ao ler notas (host=$(_remote_host), projeto=$(_gitlab_project_path))." >&2
                echo "   Verifique autenticação (glab auth status), host e projeto-alvo." >&2
                return 1
            fi
            printf '%s' "$notes"
            ;;
        github)
            local repo
            repo=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
            gh api "/repos/$repo/issues/$issue_number/comments" 2>/dev/null
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Update issue description/body
issue_update_body() {
    local issue_number="$1"
    local body="$2"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _guard_remote_matches gitlab
            glab issue update "$issue_number" $(_glab_repo_flag) -d "$body"
            ;;
        github)
            gh issue edit "$issue_number" --body "$body"
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Create comment/note on issue
issue_create_comment() {
    local issue_number="$1"
    local comment_body="$2"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _guard_remote_matches gitlab
            glab issue note "$issue_number" $(_glab_repo_flag) -m "$comment_body"
            ;;
        github)
            gh issue comment "$issue_number" --body "$comment_body"
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Check if issue exists
issue_exists() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _guard_remote_matches gitlab
            glab issue view "$issue_number" $(_glab_repo_flag) &>/dev/null
            ;;
        github)
            gh issue view "$issue_number" &>/dev/null
            ;;
        *)
            return 1
            ;;
    esac
}
