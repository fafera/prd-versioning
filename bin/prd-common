#!/bin/bash
#
# Common functions for PRD versioning scripts
# Supports both GitHub (gh) and GitLab (glab) CLI

# Normalize volatile lines (stdin -> stdout)
#
# Replaces the value of version/timestamp/status lines with a fixed
# placeholder so they never appear as changes (or as mismatched context)
# in the version diffs. Both prd-update (when generating a patch) and
# prd-restore (before reverse-applying) MUST run content through this so
# the patch context matches on both sides.
_normalize_volatile() {
    sed -E \
        -e 's/^(PRD-VERSION:).*/\1 NORMALIZED/' \
        -e 's/^(PRD-UPDATED:).*/\1 NORMALIZED/' \
        -e 's/^(\*\*Versão\*\*).*/\1: NORMALIZED/' \
        -e 's/^(\*\*Atualizado\*\*).*/\1: NORMALIZED/' \
        -e 's/^(\*\*Status\*\*).*/\1: NORMALIZED/'
}

# Print the contiguous "scaffold" at the top of a PRD (stdin -> stdout): the
# metatag comment block plus the human-readable header lines (**Versão**/
# **Atualizado**/**Criado**/**Status**) and the blank lines among them. Stops
# at the first line of substantive content.
#
# Used to align a metatag-less (legacy/pre-existing) issue description with the
# local file before diffing. Without this, adopting a legacy issue emits the
# whole scaffold as spurious "+added" lines in the first diff — which leaked
# as "PRD-VERSION: NORMALIZED" / "PRD-UPDATED: NORMALIZED" into the published
# comment.
_leading_scaffold() {
    awk '
        NR==1 && $0 ~ /^<!--/ { inblock=1; print; next }
        inblock { print; if ($0 ~ /-->/) inblock=0; next }
        /^[[:space:]]*$/ { print; next }
        /^\*\*(Versão|Versao|Atualizado|Criado|Status)\*\*/ { print; next }
        { exit }
    '
}

# Extract the unified diff inside the first ```diff fenced block of a comment
# body (stdin -> stdout). Used by prd-restore to recover the patch text.
_extract_diff_block() {
    awk '
        /^```diff[[:space:]]*$/ { inblock=1; next }
        /^```[[:space:]]*$/     { if (inblock) { inblock=0 } ; next }
        inblock { print }
    '
}

# Extract the host (e.g. greatcode.aztecweb.net) from the origin remote URL,
# handling both ssh (git@host:path) and https (https://host/path) forms.
_remote_host() {
    local url
    url=$(git remote get-url origin 2>/dev/null || echo "")
    [[ -z "$url" ]] && url=$(git remote -v 2>/dev/null | grep -oE '\S+\.\S+' | head -1)
    echo "$url" | sed -E 's#^[a-zA-Z]+://##; s#^[^@]+@##; s#[:/].*$##'
}

# Detect which platform we're using
#
# Order: explicit override -> obvious host name -> CLI host config
# (catches self-hosted GitLab/GitHub on custom domains) -> CLI availability.
_detect_platform() {
    # Check environment variable first
    if [[ -n "$PRD_PLATFORM" ]]; then
        echo "$PRD_PLATFORM"
        return
    fi

    # Check git remote for obvious platform patterns
    local remote
    remote=$(git remote -v 2>/dev/null || echo "")

    if echo "$remote" | grep -qiE '(gitlab\.|@gitlab|//gitlab)'; then
        echo "gitlab"
        return
    elif echo "$remote" | grep -qiE '(github\.|@github|//github)'; then
        echo "github"
        return
    fi

    # Self-hosted on a custom domain: match the remote host against the hosts
    # each CLI has authenticated to (offline lookup, no network call).
    local host host_re glab_cfg gh_cfg
    host=$(_remote_host)
    if [[ -n "$host" ]]; then
        host_re=$(echo "$host" | sed 's/\./\\./g')
        glab_cfg="${GLAB_CONFIG_DIR:-$HOME/.config/glab-cli}/config.yml"
        gh_cfg="${GH_CONFIG_DIR:-$HOME/.config/gh}/hosts.yml"
        if grep -qE "^[[:space:]]+${host_re}:" "$glab_cfg" 2>/dev/null; then
            echo "gitlab"
            return
        elif grep -qE "^${host_re}:" "$gh_cfg" 2>/dev/null; then
            echo "github"
            return
        fi
    fi

    # Fallback: check which CLI is available
    if command -v glab &>/dev/null && ! command -v gh &>/dev/null; then
        echo "gitlab"
    elif command -v gh &>/dev/null && ! command -v glab &>/dev/null; then
        echo "github"
    else
        echo "unknown"
    fi
}

# Get issue URL from output
_get_issue_url_from_output() {
    local output="$1"
    echo "$output" | grep -oE 'https://[^ ]+' | head -1
}

# Get issue number from URL
_get_issue_number_from_url() {
    local url="$1"
    # GitHub: https://github.com/owner/repo/issues/123
    # GitLab: https://gitlab.com/owner/repo/-/issues/123
    # GitLab (newer): https://host/owner/repo/-/work_items/123
    echo "$url" | grep -oE '/(issues|work_items)/[0-9]+' | grep -oE '[0-9]+' | head -1
}

# Fetch a single issue as JSON via the GitLab API (uses the :fullpath
# placeholder resolved from the current repo's remote). Robust against
# description content that contains '---' or other markup.
_gitlab_issue_json() {
    local iid="$1"
    glab api "projects/:fullpath/issues/$iid" 2>/dev/null
}

# Create issue
issue_create() {
    local platform=$(_detect_platform)
    local title="$1"
    local body="$2"
    local labels="$3"

    case "$platform" in
        gitlab)
            if [[ -n "$labels" ]]; then
                glab issue create -y -t "$title" -d "$body" -l "$labels"
            else
                glab issue create -y -t "$title" -d "$body"
            fi
            ;;
        github)
            if [[ -n "$labels" ]]; then
                gh issue create --title "$title" --body "$body" --label "$labels"
            else
                gh issue create --title "$title" --body "$body"
            fi
            ;;
        *)
            echo "❌ Platform not detected. Please set PRD_PLATFORM=github or PRD_PLATFORM=gitlab"
            exit 1
            ;;
    esac
}

# Get issue title
issue_get_title() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _gitlab_issue_json "$issue_number" | jq -r '.title // empty'
            ;;
        github)
            gh issue view "$issue_number" --json title --jq .title 2>/dev/null
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Get issue body/description
issue_get_body() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            _gitlab_issue_json "$issue_number" | jq -r '.description // empty'
            ;;
        github)
            gh issue view "$issue_number" --json body --jq .body 2>/dev/null
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Get issue comments/notes
issue_get_comments() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            # Notes as JSON, oldest first, large page to cover long chains.
            # Both GitHub comments and GitLab notes expose a `.body`, so the
            # callers' `jq '.[].body'` works uniformly across platforms.
            glab api "projects/:fullpath/issues/$issue_number/notes?per_page=100&sort=asc" 2>/dev/null
            ;;
        github)
            local repo
            repo=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
            gh api "/repos/$repo/issues/$issue_number/comments" 2>/dev/null
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Update issue description/body
issue_update_body() {
    local issue_number="$1"
    local body="$2"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            glab issue update "$issue_number" -d "$body"
            ;;
        github)
            gh issue edit "$issue_number" --body "$body"
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Create comment/note on issue
issue_create_comment() {
    local issue_number="$1"
    local comment_body="$2"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            glab issue note "$issue_number" -m "$comment_body"
            ;;
        github)
            gh issue comment "$issue_number" --body "$comment_body"
            ;;
        *)
            echo "❌ Platform not detected"
            return 1
            ;;
    esac
}

# Check if issue exists
issue_exists() {
    local issue_number="$1"
    local platform=$(_detect_platform)

    case "$platform" in
        gitlab)
            glab issue view "$issue_number" &>/dev/null
            ;;
        github)
            gh issue view "$issue_number" &>/dev/null
            ;;
        *)
            return 1
            ;;
    esac
}
