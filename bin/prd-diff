#!/bin/bash
#
# Ver as mudanças de um PRD candidato vs. a descrição AO VIVO da issue.
# Mostra exatamente o diff que o prd-update publicaria (linhas voláteis
# normalizadas). ATENÇÃO: este script NÃO usa git e NÃO apaga o arquivo.
#
# Uso: ./bin/prd-diff <issue-number> <prd-file>

set -e

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Ver mudanças de um PRD candidato vs. descrição ao vivo da issue"
    echo ""
    echo "Uso: $0 <issue-number> <prd-file>"
    echo ""
    echo "Argumentos:"
    echo "  issue-number  Número da issue (GitHub ou GitLab)"
    echo "  prd-file      Arquivo com o conteúdo editado do PRD"
    echo ""
    echo "Nota: Compara o arquivo com a descrição publicada na issue,"
    echo "      normalizando linhas voláteis (versão/data/status)."
    echo "      Read-only: não publica nada e não apaga o arquivo."
    exit 0
}

if [[ $# -lt 2 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_issue_number="$1"
_prd_file="$2"

if [[ -z "$_issue_number" ]]; then
    echo "❌ Número da issue é obrigatório"
    exit 1
fi

if [[ ! -f "$_prd_file" ]]; then
    echo "❌ Arquivo não encontrado: $_prd_file"
    echo "   Salve o conteúdo editado num arquivo e tente de novo."
    exit 1
fi

# Fetch live description
_desc=$(issue_get_body "$_issue_number" || echo "")
if [[ -z "$_desc" ]]; then
    echo "❌ Não foi possível obter a descrição da issue #$_issue_number"
    exit 1
fi

_from_version=$(echo "$_desc" | grep -oP 'PRD-VERSION: \K[0-9.]+' | head -1 || echo "?")
_local_version=$(grep -oP 'PRD-VERSION: \K[0-9.]+' "$_prd_file" | head -1 || echo "?")

_tmp_dir=$(mktemp -d)
trap 'rm -rf "$_tmp_dir"' EXIT
echo "$_desc" | _normalize_volatile > "$_tmp_dir/published"
_normalize_volatile < "$_prd_file" > "$_tmp_dir/local"

echo "🔍 Diff: descrição publicada (v$_from_version) → candidato (v$_local_version)"
echo "🔗 Issue: #$_issue_number"
echo ""
echo '```diff'
diff -u "$_tmp_dir/published" "$_tmp_dir/local" | tail -n +3 || true
echo '```'
echo ""
echo "💡 Para publicar estas mudanças:"
echo "   ./bin/prd-update $_issue_number $_prd_file"
