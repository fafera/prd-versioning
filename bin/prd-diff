#!/bin/bash
#
# Ver as mudanças do PRD local vs. a descrição AO VIVO da issue.
# Mostra exatamente o diff que o prd-update publicaria (linhas voláteis
# normalizadas). ATENÇÃO: este script NÃO usa git.

set -e

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Ver mudanças do PRD local vs. descrição ao vivo da issue"
    echo ""
    echo "Uso: $0 <prd-file>"
    echo ""
    echo "Argumentos:"
    echo "  prd-file  Caminho do arquivo PRD"
    echo ""
    echo "Nota: Compara o arquivo local com a descrição publicada na issue,"
    echo "      normalizando linhas voláteis (versão/data/status)."
    exit 0
}

if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_prd_file="$1"

if [[ ! -f "$_prd_file" ]]; then
    echo "❌ PRD não encontrado: $_prd_file"
    exit 1
fi

# Resolve issue number from metatags / filename
_issue_number=$(grep -oP 'ISSUE-NUMBER: \K[0-9]+' "$_prd_file" || echo "")
if [[ -z "$_issue_number" ]]; then
    _issue_number=$(basename "$_prd_file" | grep -oP 'prd-\K[0-9]+' || echo "")
fi
if [[ -z "$_issue_number" ]]; then
    echo "❌ Não foi possível descobrir o número da issue a partir do PRD"
    exit 1
fi

# Fetch live description
_desc=$(issue_get_body "$_issue_number" || echo "")
if [[ -z "$_desc" ]]; then
    echo "❌ Não foi possível obter a descrição da issue #$_issue_number"
    exit 1
fi

_from_version=$(echo "$_desc" | grep -oP 'PRD-VERSION: \K[0-9.]+' | head -1 || echo "?")
_local_version=$(grep -oP 'PRD-VERSION: \K[0-9.]+' "$_prd_file" | head -1 || echo "?")

_tmp_dir=$(mktemp -d)
trap 'rm -rf "$_tmp_dir"' EXIT
echo "$_desc" | _normalize_volatile > "$_tmp_dir/published"
_normalize_volatile < "$_prd_file" > "$_tmp_dir/local"

echo "🔍 Diff: descrição publicada (v$_from_version) → local (v$_local_version)"
echo "🔗 Issue: #$_issue_number"
echo ""
echo '```diff'
diff -u "$_tmp_dir/published" "$_tmp_dir/local" | tail -n +3 || true
echo '```'
echo ""
echo "💡 Para publicar estas mudanças:"
echo "   ./bin/prd-update $_prd_file"
