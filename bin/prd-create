#!/bin/bash
#
# Criar PRD local e issue no GitHub/GitLab (Cenário 1)
# Uso: ./bin/prd-create <prd-id> "<title>" [labels]
#
# Exemplo: ./bin/prd-create "hpos-compatibilidade" "Compatibilização com HPOS" "feature"

set -e

# Source common functions
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Criar PRD local e issue no GitHub/GitLab"
    echo ""
    echo "Uso: $0 <prd-id> \"<title>\" [labels]"
    echo ""
    echo "Argumentos:"
    echo "  prd-id   Identificador único do PRD (ex: hpos-compatibilidade)"
    echo "  title    Título da issue"
    echo "  labels   Labels separadas por vírgula (opcional)"
    echo ""
    echo "Exemplos:"
    echo "  $0 hpos-compat \"Compatibilidade HPOS\" feature"
    echo "  $0 pix-auto \"PIX Automático\" \"feature,high-priority\""
    echo ""
    echo "Nota: Cria PRD com metatag de identificação"
    echo "      Detecta automaticamente GitHub ou GitLab"
    echo "      Override: PRD_PLATFORM=github|gitlab $0 ..."
    exit 0
}

# Parse arguments
if [[ $# -lt 2 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_prd_id="$1"
_title="$2"
_labels="${3:-}"

# Validate
if [[ -z "$_prd_id" ]]; then
    echo "❌ PRD-ID é obrigatório"
    exit 1
fi

if [[ -z "$_title" ]]; then
    echo "❌ Título é obrigatório"
    exit 1
fi

# Check if PRD already exists
_prd_file="prd/$_prd_id.md"
if [[ -f "$_prd_file" ]]; then
    echo "⚠️  PRD já existe: $_prd_file"
    echo "Use './bin/prd-update $_prd_file' para atualizar"
    exit 0
fi

# Create prd directory if not exists
mkdir -p prd

# Generate timestamp
_timestamp=$(date +"%Y-%m-%d %H:%M:%S")

# Create initial PRD with metatags
echo "📄 Criando PRD inicial com metatags..."
cat > "$_prd_file" << EOF
<!--
PRD-ID: $_prd_id
PRD-VERSION: 1.0
PRD-UPDATED: $_timestamp
-->

# PRD: $_title

**Versão**: 1.0
**Criado**: $(date +"%d/%m/%Y %H:%M")
**Status**: 🟡 Em Revisão

---

## 1. Resumo Executivo

### Declaração do Problema
[Descrever o problema que esta feature resolve]

### Solução Proposta
[Descrever a solução proposta]

### Critérios de Sucesso
- [ ] Critério 1
- [ ] Critério 2
- [ ] Critério 3

## 2. Experiência do Usuário e Funcionalidade

### Personas de Usuário
- **Persona 1**: [Descrição]
- **Persona 2**: [Descrição]

### User Stories
**Como** [usuário],
**Eu quero** [ação],
**Para que** [benefício].

### Critérios de Aceite
- [ ] Critério de aceite 1
- [ ] Critério de aceite 2

## 3. Especificações Técnicas

### Pontos de Integração
[Detalhes técnicos da implementação]

### Arquivos Requerendo Modificação
1. **Arquivo 1**: [Motivo da mudança]
2. **Arquivo 2**: [Motivo da mudança]

## 4. Estratégia de Testes

### Testes Automatizados
- [ ] Teste 1
- [ ] Teste 2

### Testes Manuais
- [ ] Caso de teste 1
- [ ] Caso de teste 2

## 5. Riscos e Roadmap

### Fase 1: [Objetivo]
- [ ] Tarefa 1
- [ ] Tarefa 2

### Fase 2: [Objetivo]
- [ ] Tarefa 1
- [ ] Tarefa 2

---
EOF

# Detect platform for output message
_platform=$(_detect_platform)
_platform_name="GitHub"
[[ "$_platform" == "gitlab" ]] && _platform_name="GitLab"

# Create issue with PRD in description
echo "🎯 Criando issue no $_platform_name..."
_issue_output=$(issue_create "$_title" "$(cat "$_prd_file")" "$_labels")

# Extract issue URL and number
_issue_url=$(_get_issue_url_from_output "$_issue_output")
_issue_number=$(_get_issue_number_from_url "$_issue_url")

if [[ -z "$_issue_number" ]]; then
    echo "❌ Falha ao criar issue ou obter número da issue"
    echo "Output: $_issue_output"
    exit 1
fi

# Add ISSUE-NUMBER to PRD metatags and update title
echo "🏷️  Adicionando número da issue ao PRD..."
sed -i "4 i\\ISSUE-NUMBER: $_issue_number" "$_prd_file"
sed -i "s/# PRD: $_title/# PRD para Issue #$_issue_number: $_title/" "$_prd_file"

# Sync issue body with the finalized PRD (metatags + corrected title)
echo "🔄 Sincronizando corpo da issue..."
issue_update_body "$_issue_number" "$(cat "$_prd_file")" > /dev/null

echo ""
echo "✅ Issue criada com sucesso!"
echo "🔗 Issue: #$_issue_number - $_issue_url"
echo "📄 PRD local: $_prd_file"
echo "🏷️  PRD-ID: $_prd_id"
echo "🔧 Plataforma: $_platform_name"
echo ""
echo "📋 Próximos passos:"
echo "   1. Edite o PRD: vim $_prd_file"
echo "   2. Ver mudanças: ./bin/prd-diff $_prd_file"
echo "   3. Atualize a issue: ./bin/prd-update $_prd_file"
echo ""
echo "⚠️  Lembre-se: PRDs ficam apenas localmente, não são commitados no git"
