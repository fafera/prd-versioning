#!/bin/bash
#
# Adotar uma issue existente para o versionamento de PRD (Cenário 1).
#
# A issue normalmente já foi criada pelo /to-prd (com a estrutura correta).
# Este comando NÃO cria a issue: ele carimba as metatags de versionamento
# (PRD-ID, PRD-VERSION 1.0, ISSUE-NUMBER) e o cabeçalho de status na
# DESCRIÇÃO AO VIVO, estabelecendo a baseline v1.0. A partir daí, prd-update
# registra cada transição como diff e prd-restore consegue caminhar a cadeia.
#
# Idempotente: se a descrição já tiver PRD-ID, não faz nada.
# Não deixa nenhum arquivo local — a issue é a fonte da verdade.
#
# Uso: ./bin/prd-create <issue-number> [prd-id]
# Exemplo: ./bin/prd-create 390
#          ./bin/prd-create 390 hpos-compatibilidade

set -e

# Source common functions
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Adotar issue existente para versionamento de PRD (carimba metatags v1.0)"
    echo ""
    echo "Uso: $0 <issue-number> [prd-id]"
    echo ""
    echo "Argumentos:"
    echo "  issue-number  Número da issue (criada pelo /to-prd ou manualmente)"
    echo "  prd-id        Identificador do PRD (opcional; derivado do título)"
    echo ""
    echo "Carimba PRD-ID/PRD-VERSION/ISSUE-NUMBER + cabeçalho de status na"
    echo "descrição ao vivo. Idempotente. Não cria arquivos locais."
    echo ""
    echo "Nota: Detecta automaticamente GitHub ou GitLab"
    echo "      Override: PRD_PLATFORM=github|gitlab $0 ..."
    exit 0
}

# Parse arguments
if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_issue_number="$1"
_prd_id="${2:-}"

if [[ -z "$_issue_number" ]]; then
    echo "❌ Número da issue é obrigatório"
    exit 1
fi

_platform=$(_detect_platform)
_platform_name="GitHub"
[[ "$_platform" == "gitlab" ]] && _platform_name="GitLab"
_guard_remote_matches "$_platform"

# Fetch the live description (source of truth)
echo "📥 Baixando descrição da issue #$_issue_number ($_platform_name)..."
_desc=$(issue_get_body "$_issue_number" || echo "")
if [[ -z "$_desc" ]]; then
    echo "❌ Descrição da issue #$_issue_number vazia ou inacessível"
    exit 1
fi

# Already adopted? Idempotent no-op.
if echo "$_desc" | grep -q 'PRD-ID:'; then
    _existing=$(echo "$_desc" | grep -oP 'PRD-ID: \K\S+' | head -1)
    echo "ℹ️  Issue já versionada (PRD-ID: $_existing). Nada a fazer."
    echo "   Edite com: ./bin/prd-sync $_issue_number  →  ./bin/prd-update $_issue_number <arquivo>"
    exit 0
fi

# Derive PRD-ID from title when not provided
if [[ -z "$_prd_id" ]]; then
    _issue_title=$(issue_get_title "$_issue_number")
    _prd_id=$(echo "$_issue_title" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-30 | sed -E 's/-+$//')
    [[ -z "$_prd_id" ]] && _prd_id=$(echo "$_issue_title" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-30 | sed -E 's/-+$//')
    [[ -z "$_prd_id" ]] && _prd_id="prd-$_issue_number"
fi

_timestamp=$(date +"%Y-%m-%d %H:%M:%S")
_date_br=$(date +"%d/%m/%Y %H:%M")

# Build the versioning scaffold and prepend it to the existing description
_header=$(cat <<EOF
<!--
PRD-ID: $_prd_id
PRD-VERSION: 1.0
ISSUE-NUMBER: $_issue_number
PRD-UPDATED: $_timestamp
-->

**Versão**: v1.0
**Atualizado**: $_date_br
**Status**: 🟡 Em Revisão

EOF
)

_new_desc=$(printf '%s\n\n%s\n' "$_header" "$_desc")

echo "🏷️  Carimbando metatags v1.0 na descrição da issue..."
issue_update_body "$_issue_number" "$_new_desc" > /dev/null

echo ""
echo "✅ Issue adotada para versionamento!"
echo "🏷️  PRD-ID: $_prd_id"
echo "📊 Versão: v1.0 (baseline)"
echo "🔗 Issue: #$_issue_number"
echo "🔧 Plataforma: $_platform_name"
echo ""
echo "📋 Próximos passos:"
echo "   1. Ler o PRD atual:  ./bin/prd-sync $_issue_number"
echo "   2. Editar o conteúdo no contexto e salvar em arquivo temporário"
echo "   3. Publicar mudanças: ./bin/prd-update $_issue_number <arquivo>"
