#!/bin/bash
#
# Atualizar PRD: sobrescrever a descrição da issue com o documento completo
# e publicar um comentário contendo APENAS o diff da transição de versão.
#
# Modelo:
#   - Descrição da issue  = sempre o documento completo mais recente
#   - Comentário          = diff puro (patch aplicável) de uma transição
#
# O 'antes' do diff é a descrição AO VIVO da issue (estado publicado real).
# Linhas voláteis (versão/data/status) são normalizadas antes de diffar para
# não poluírem o patch nem quebrarem o prd-restore.
#
# O conteúdo novo chega via <prd-file> (escrito pelo agente). No sucesso, o
# arquivo é APAGADO se estiver dentro da base temporária — nada persiste.
#
# Uso:
#   ./bin/prd-update <issue-number> <prd-file>            # versão auto-incrementada
#   ./bin/prd-update <issue-number> <prd-file> [version]  # versão específica

set -e

# Source common functions
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Atualizar PRD: descrição = completo, comentário = diff puro"
    echo ""
    echo "Uso:"
    echo "  $0 <issue-number> <prd-file> [version]"
    echo ""
    echo "Argumentos:"
    echo "  issue-number  Número da issue (GitHub ou GitLab)"
    echo "  prd-file      Arquivo com o conteúdo completo editado do PRD"
    echo "  version       Nova versão (opcional, auto-incrementada se omitida)"
    echo ""
    echo "Exemplos:"
    echo "  $0 390 /tmp/prd-versioning/repo/hpos.md"
    echo "  $0 390 /tmp/prd-versioning/repo/hpos.md v2.0"
    echo ""
    echo "Nota: Detecta automaticamente GitHub ou GitLab"
    echo "      Sobrescreve a descrição; comenta só o diff; apaga o arquivo"
    exit 0
}

# Function to increment version (minor bump)
_increment_version() {
    local version=$1
    local major minor
    major=$(echo "$version" | grep -oP '^[0-9]+' || echo "1")
    minor=$(echo "$version" | grep -oP '\.[0-9]+$' | tr -d '.' || echo "0")
    minor=$((minor + 1))
    echo "${major}.${minor}"
}

# Parse arguments
if [[ $# -lt 2 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_issue_number="$1"
_prd_file="$2"
_version="${3#v}"

# Validate
if [[ -z "$_issue_number" ]]; then
    echo "❌ Número da issue é obrigatório"
    exit 1
fi

if [[ ! -f "$_prd_file" ]]; then
    echo "❌ PRD não encontrado: $_prd_file"
    echo "   Salve o conteúdo editado num arquivo e tente de novo."
    exit 1
fi

# Detect platform
_platform=$(_detect_platform)
_platform_name="GitHub"
[[ "$_platform" == "gitlab" ]] && _platform_name="GitLab"
_guard_remote_matches "$_platform"

# Fetch the LIVE issue description (the real published state) as the diff base
echo "📥 Baixando descrição ao vivo da issue #$_issue_number ($_platform_name)..."
_desc=$(issue_get_body "$_issue_number" || echo "")

if [[ -z "$_desc" ]]; then
    echo "❌ Não foi possível obter a descrição da issue #$_issue_number"
    exit 1
fi

if ! echo "$_desc" | grep -q 'PRD-ID:'; then
    echo "❌ A descrição não tem metatags de versionamento."
    echo "   Adote a issue primeiro: ./bin/prd-create $_issue_number"
    exit 1
fi

# FROM version = version published in the description (authoritative baseline)
_from_version=$(echo "$_desc" | grep -oP 'PRD-VERSION: \K[0-9.]+' | head -1 || echo "")
if [[ -z "$_from_version" ]]; then
    _from_version=$(grep -oP 'PRD-VERSION: \K[0-9.]+' "$_prd_file" | head -1 || echo "1.0")
fi

# TO version = provided or auto-incremented
if [[ -z "$_version" ]]; then
    _version=$(_increment_version "$_from_version")
fi

# Build normalized temp files for diffing (volatile lines neutralized).
_tmp_dir=$(mktemp -d)
trap 'rm -rf "$_tmp_dir"' EXIT
_before="$_tmp_dir/before"
_after="$_tmp_dir/after"
echo "$_desc" | _normalize_volatile > "$_before"
_normalize_volatile < "$_prd_file" > "$_after"

# Generate an applicable unified diff (clean header labels for readability;
# prd-restore passes the target file explicitly, so headers are cosmetic)
echo "🔍 Calculando diff v$_from_version → v$_version..."
_diff=$(diff -u "$_before" "$_after" || true)
_diff=$(echo "$_diff" \
    | sed -e "1s|^--- .*|--- PRD v$_from_version|" \
          -e "2s|^+++ .*|+++ PRD v$_version|")

if [[ -z "$_diff" ]]; then
    echo "ℹ️  Nenhuma mudança de conteúdo detectada (apenas linhas voláteis)."
    echo "    Nada a publicar — abortando para manter a cadeia limpa."
    echo "    O arquivo foi mantido: $_prd_file"
    exit 0
fi

echo "   Linhas de diff: $(echo "$_diff" | wc -l)"

# Stamp metatags + volatile body lines only after confirming a real change.
_timestamp=$(date +"%Y-%m-%d %H:%M:%S")
echo "📝 Atualizando metatags para v$_version..."
sed -i "s/PRD-VERSION: .*/PRD-VERSION: $_version/" "$_prd_file"
sed -i "s/PRD-UPDATED: .*/PRD-UPDATED: $_timestamp/" "$_prd_file"
sed -i -E "s/\*\*Versão\*\*.*$/\*\*Versão\*\*: v$_version/" "$_prd_file"
sed -i -E "s/\*\*Atualizado\*\*.*$/\*\*Atualizado\*\*: $(date +"%d\/%m\/%Y %H:%M")/" "$_prd_file"

# Extract PRD-ID
_prd_id=$(grep -oP 'PRD-ID: \K\S+' "$_prd_file" || echo "unknown")

# Build comment: hidden machine-readable chain metatags + visible diff only
_comment_body="<!--
PRD-ID: $_prd_id
ISSUE-NUMBER: $_issue_number
PRD-DIFF-FROM: $_from_version
PRD-DIFF-TO: $_version
-->

## 📋 PRD v$_version — Mudanças desde v$_from_version

**PRD-ID**: \`$_prd_id\` · **Publicado**: $(date +"%d/%m/%Y %H:%M") · **Status**: 🟡 Em Revisão

> Documento completo: ver **descrição da issue**. Recuperar esta versão: \`./bin/prd-restore $_issue_number v$_from_version\`

\`\`\`diff
$_diff
\`\`\`"

# Publish the diff comment
echo "💬 Publicando diff como comentário na issue #$_issue_number..."
issue_create_comment "$_issue_number" "$_comment_body"

# Overwrite the issue description with the full latest document
echo "📄 Sobrescrevendo descrição com o documento completo (v$_version)..."
issue_update_body "$_issue_number" "$(cat "$_prd_file")" > /dev/null

# Nothing persists: drop the input file (only if inside the scratch base).
_prd_cleanup_input "$_prd_file"

echo ""
echo "✅ PRD atualizado com sucesso!"
echo "🏷️  PRD-ID: $_prd_id"
echo "🔗 Issue: #$_issue_number"
echo "📊 Versão: v$_from_version → v$_version"
echo "🔧 Plataforma: $_platform_name"
echo ""
echo "💡 Recuperar versão anterior: ./bin/prd-restore $_issue_number v$_from_version"
echo "💡 Continuar editando: ./bin/prd-sync $_issue_number"
