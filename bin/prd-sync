#!/bin/bash
#
# Imprimir o PRD mais recente da issue no stdout (Cenário 2).
#
# O PRD mais recente vive SEMPRE na descrição da issue (fonte da verdade).
# Os comentários contêm apenas diffs de versão; nunca reconstruímos o PRD
# a partir deles. Para recuperar uma versão antiga, use ./bin/prd-restore.
#
# Não persiste nenhum arquivo: o conteúdo vai para o stdout e a cópia de
# trabalho fica no contexto do agente. Para editar, capture esta saída,
# altere, salve num arquivo temporário e publique com ./bin/prd-update.
#
# Uso: ./bin/prd-sync <issue-number>

set -e

# Source common functions
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Imprimir o PRD mais recente da issue no stdout"
    echo "Uso: $0 <issue-number>"
    echo ""
    echo "Argumentos:"
    echo "  issue-number  Número da issue (GitHub ou GitLab)"
    echo ""
    echo "O PRD mais recente vive SEMPRE na descrição da issue."
    echo "Os comentários contêm apenas diffs (ver ./bin/prd-restore)."
    echo ""
    echo "Nota: Detecta automaticamente GitHub ou GitLab"
    echo "      Não cria arquivos — imprime a descrição no stdout"
    exit 0
}

# Parse arguments
if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_issue_number="$1"

if [[ -z "$_issue_number" ]]; then
    echo "❌ Número da issue é obrigatório" >&2
    exit 1
fi

# Diagnostics go to stderr so stdout carries ONLY the PRD content.
_platform=$(_detect_platform)
_platform_name="GitHub"
[[ "$_platform" == "gitlab" ]] && _platform_name="GitLab"

echo "📝 Buscando PRD da issue #$_issue_number ($_platform_name)..." >&2
_prd_content=$(issue_get_body "$_issue_number")

if [[ -z "$_prd_content" ]]; then
    echo "❌ Descrição da issue vazia — nada para sincronizar" >&2
    exit 1
fi

if ! echo "$_prd_content" | grep -q 'PRD-ID:'; then
    echo "⚠️  Issue ainda não versionada (sem metatags)." >&2
    echo "    Rode './bin/prd-create $_issue_number' para adotá-la antes de versionar." >&2
fi

# The PRD content (latest full document) — the only thing on stdout.
printf '%s\n' "$_prd_content"
