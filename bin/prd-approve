#!/bin/bash
#
# Aprovar PRD e preparar para implementação
# ATENÇÃO: Este script NÃO faz commits no git

set -e

# Source common functions
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Aprovar PRD e preparar para implementação"
    echo ""
    echo "Uso: $0 <prd-file> [version]"
    echo ""
    echo "Argumentos:"
    echo "  prd-file  Caminho do arquivo PRD"
    echo "  version   Versão do PRD a ser aprovada (opcional)"
    echo ""
    echo "Nota: Detecta automaticamente GitHub ou GitLab"
    echo "      Atualiza status no PRD e publica aprovação na issue"
    exit 0
}

# Parse arguments
if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_prd_file="$1"
_version="$2"

# Validate
if [[ ! -f "$_prd_file" ]]; then
    echo "❌ PRD não encontrado: $_prd_file"
    exit 1
fi

# Get current version from metatag
_current_version=$(grep -oP 'PRD-VERSION: \K[0-9.]+' "$_prd_file" || echo "1.0")

# Use provided version or current version
if [[ -z "$_version" ]]; then
    _version="v$_current_version"
elif [[ ! "$_version" =~ ^v[0-9] ]]; then
    _version="v$_version"
fi

# Extract issue number from metatag first (priority)
_issue_number=$(grep -oP 'ISSUE-NUMBER: \K[0-9]+' "$_prd_file" || echo "")

# If not in metatags, try content
if [[ -z "$_issue_number" ]]; then
    _issue_number=$(grep -oP 'Issue #[0-9]+' "$_prd_file" | head -1 | grep -oP '[0-9]+' || echo "")
fi

# If not in content, try filename
if [[ -z "$_issue_number" ]]; then
    _issue_number=$(basename "$_prd_file" | grep -oP 'prd-\K[0-9]+' || echo "")
fi

# If still not found, ask user
if [[ -z "$_issue_number" ]]; then
    echo "⚠️  Não foi possível encontrar número da issue automaticamente"
    read -p "Digite o número da issue: " _issue_number
fi

if [[ -z "$_issue_number" ]]; then
    echo "❌ Número da issue é obrigatório"
    exit 1
fi

# Get PRD-ID
_prd_id=$(grep -oP 'PRD-ID: \K[A-Za-z0-9_-]+' "$_prd_file" || echo "unknown")

# Detect platform
_platform=$(_detect_platform)
_platform_name="GitHub"
[[ "$_platform" == "gitlab" ]] && _platform_name="GitLab"

# Get issue title
_issue_title=$(issue_get_title "$_issue_number")

# Create approval comment
_approve_body="## ✅ PRD $_version Aprovado

**PRD-ID**: $_prd_id
**Aprovado por**: $(git config user.name 2>/dev/null || echo "Unknown") em $(date +"%d/%m/%Y %H:%M")

### Próximos Passos:
1. Criar branch de implementação: \`git checkout -b feature/issue-$_issue_number\`
2. Seguir o PRD: $_prd_file
3. Criar merge/pull request quando pronto

---

📋 **PRD**: $_prd_file
🔗 **Issue**: #$_issue_number"

# Publish approval comment
echo "💬 Publicando aprovação na issue #$_issue_number ($_platform_name)..."
issue_create_comment "$_issue_number" "$_approve_body"

# Update status line in the LIVE issue description (source of truth).
# Status is a volatile line, normalized out of the diff chain, so editing it
# here does not break prd-restore.
echo "📝 Atualizando status na descrição da issue..."
_desc=$(issue_get_body "$_issue_number" || echo "")
if [[ -n "$_desc" ]] && echo "$_desc" | grep -q '\*\*Status\*\*:'; then
    _new_desc=$(echo "$_desc" | sed -E "s/\*\*Status\*\*.*$/\*\*Status\*\*: 🟢 Aprovado (aprovado em $(date +"%d\/%m\/%Y"))/")
    issue_update_body "$_issue_number" "$_new_desc" > /dev/null
fi

# Update status in local PRD file too (if present)
if grep -q '\*\*Status\*\*:' "$_prd_file"; then
    sed -i -E "s/\*\*Status\*\*.*$/\*\*Status\*\*: 🟢 Aprovado (aprovado em $(date +"%d\/%m\/%Y"))/" "$_prd_file"
fi

echo ""
echo "✅ PRD aprovado com sucesso!"
echo "🏷️  PRD-ID: $_prd_id"
echo "📊 Versão: $_version"
echo "🔗 Issue: #$_issue_number"
echo "🔧 Plataforma: $_platform_name"
echo ""
echo "📋 Para começar a implementação:"
echo "   git checkout -b feature/issue-$_issue_number"
