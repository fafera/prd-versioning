#!/bin/bash
#
# Aprovar PRD e preparar para implementação.
# Lê tudo da descrição AO VIVO da issue (fonte da verdade) — não usa arquivo
# local. ATENÇÃO: Este script NÃO faz commits no git.
#
# Uso: ./bin/prd-approve <issue-number> [version]

set -e

# Source common functions
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_script_dir/prd-common"

_show_help() {
    echo "Aprovar PRD e preparar para implementação"
    echo ""
    echo "Uso: $0 <issue-number> [version]"
    echo ""
    echo "Argumentos:"
    echo "  issue-number  Número da issue (GitHub ou GitLab)"
    echo "  version       Versão a aprovar (opcional; lida da descrição)"
    echo ""
    echo "Nota: Detecta automaticamente GitHub ou GitLab"
    echo "      Lê da descrição ao vivo; atualiza status e publica aprovação"
    exit 0
}

# Parse arguments
if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    _show_help
fi

_issue_number="$1"
_version="$2"

if [[ -z "$_issue_number" ]]; then
    echo "❌ Número da issue é obrigatório"
    exit 1
fi

# Detect platform
_platform=$(_detect_platform)
_platform_name="GitHub"
[[ "$_platform" == "gitlab" ]] && _platform_name="GitLab"
_guard_remote_matches "$_platform"

# Fetch live description (source of truth)
echo "📥 Baixando descrição da issue #$_issue_number ($_platform_name)..."
_desc=$(issue_get_body "$_issue_number" || echo "")
if [[ -z "$_desc" ]]; then
    echo "❌ Não foi possível obter a descrição da issue #$_issue_number"
    exit 1
fi

# Resolve version + PRD-ID from the description
_current_version=$(echo "$_desc" | grep -oP 'PRD-VERSION: \K[0-9.]+' | head -1 || echo "1.0")
if [[ -z "$_version" ]]; then
    _version="v$_current_version"
elif [[ ! "$_version" =~ ^v[0-9] ]]; then
    _version="v$_version"
fi

_prd_id=$(echo "$_desc" | grep -oP 'PRD-ID: \K\S+' | head -1 || echo "unknown")

# Get issue title and build branch name (<issue-id>-<titulo-slugificado>)
_issue_title=$(issue_get_title "$_issue_number")
_title_slug=$(echo "$_issue_title" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-50 | sed -E 's/-+$//')
[[ -z "$_title_slug" ]] && _title_slug=$(echo "$_issue_title" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-50 | sed -E 's/-+$//')
_branch="$_issue_number-$_title_slug"

# Create approval comment
_approve_body="## ✅ PRD $_version Aprovado

**PRD-ID**: $_prd_id
**Aprovado por**: $(git config user.name 2>/dev/null || echo "Unknown") em $(date +"%d/%m/%Y %H:%M")

### Próximos Passos:
1. Criar branch de implementação: \`git checkout -b $_branch\`
2. Criar merge/pull request quando pronto"

# Publish approval comment
echo "💬 Publicando aprovação na issue #$_issue_number ($_platform_name)..."
issue_create_comment "$_issue_number" "$_approve_body"

# Update status line in the LIVE issue description (source of truth).
# Status is a volatile line, normalized out of the diff chain, so editing it
# here does not break prd-restore.
echo "📝 Atualizando status na descrição da issue..."
if echo "$_desc" | grep -q '\*\*Status\*\*:'; then
    _new_desc=$(echo "$_desc" | sed -E "s/\*\*Status\*\*.*$/\*\*Status\*\*: 🟢 Aprovado (aprovado em $(date +"%d\/%m\/%Y"))/")
    issue_update_body "$_issue_number" "$_new_desc" > /dev/null
else
    echo "⚠️  Sem linha **Status** na descrição — pulei a atualização de status."
fi

echo ""
echo "✅ PRD aprovado com sucesso!"
echo "🏷️  PRD-ID: $_prd_id"
echo "📊 Versão: $_version"
echo "🔗 Issue: #$_issue_number"
echo "🔧 Plataforma: $_platform_name"
echo ""
echo "📋 Para começar a implementação:"
echo "   git checkout -b $_branch"
